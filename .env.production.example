# Copy this file to .env.production, replace every placeholder, then set mode 600.
COMPOSE_PROJECT_NAME=smart-fish-feeder-production

# Both A/AAAA records must resolve to the VPS. Remove an AAAA record if the VPS
# is not actually reachable over IPv6.
DASHBOARD_DOMAIN=feeder.example.com
MQTT_DOMAIN=mqtt.example.com
ACME_EMAIL=operator@example.com
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# The initial physical device. MQTT_DEVICE_USERNAME must exactly match DEVICE_UID
# because the Mosquitto ACL derives the allowed topic from the authenticated user.
DEVICE_UID=feeder-001
MQTT_DEVICE_USERNAME=feeder-001

# Generate a unique value for each line, for example: openssl rand -hex 32
FISH_FEEDER_DEVICE_API_KEY=replace-with-64-random-hex-characters
FISH_FEEDER_CREDENTIAL_PEPPER=replace-with-a-different-64-random-hex-value
FISH_FEEDER_ADMIN_USERNAME=admin
FISH_FEEDER_ADMIN_PASSWORD=replace-with-a-unique-64-random-hex-value
# Public credentials are intentional: this role can access only synthetic data
# and simulated commands. Set DEMO_ENABLED=false to remove the public demo.
FISH_FEEDER_DEMO_ENABLED=true
FISH_FEEDER_DEMO_USERNAME=demo
FISH_FEEDER_DEMO_PASSWORD=smartfishdemo
FISH_FEEDER_DEMO_DEVICE_UID=demo-feeder-001
FISH_FEEDER_JWT_SECRET=replace-with-a-different-64-random-hex-value
FISH_FEEDER_ROOT_PATH=/api

# Customer registration requires transactional email. Use SMTP credentials from
# your email provider; never commit the real password. Production defaults to
# SMTP and fails a registration email safely if these values are missing.
FISH_FEEDER_EMAIL_DELIVERY_MODE=smtp
FISH_FEEDER_SMTP_HOST=smtp.example.com
FISH_FEEDER_SMTP_PORT=587
FISH_FEEDER_SMTP_USERNAME=replace-with-smtp-username
FISH_FEEDER_SMTP_PASSWORD=replace-with-smtp-app-password
FISH_FEEDER_SMTP_FROM_EMAIL=accounts@example.com
FISH_FEEDER_SMTP_STARTTLS=true
MQTT_SHARED_SECRET=replace-with-a-different-64-random-hex-value
MQTT_BRIDGE_USERNAME=bridge
MQTT_BRIDGE_PASSWORD=replace-with-a-different-64-random-hex-value
MQTT_DEVICE_PASSWORD=replace-with-a-different-64-random-hex-value

# Fail closed for physical actuation and expire unclaimed manual commands quickly.
FISH_FEEDER_REQUIRE_ONLINE_FOR_ACTUATION=true
FISH_FEEDER_MANUAL_COMMAND_TTL_SECONDS=45
FISH_FEEDER_COMMAND_LEASE_SECONDS=10
FISH_FEEDER_COMMAND_RESULT_GRACE_SECONDS=90
FISH_FEEDER_OFFLINE_AFTER_SECONDS=45
FISH_FEEDER_RELIABILITY_SCAN_INTERVAL_SECONDS=30
FISH_FEEDER_REGISTRATION_RATE_LIMIT_PER_MINUTE=5
FISH_FEEDER_PASSWORD_RESET_RATE_LIMIT_PER_MINUTE=5
FISH_FEEDER_PAIRING_RATE_LIMIT_PER_MINUTE=10
COMMAND_POLL_SECONDS=2

# Leave empty for one device. For multiple devices, both maps must contain the
# same device UIDs and the broker password/ACL initialization must also be extended.
DEVICE_CREDENTIALS_JSON=
MQTT_SHARED_SECRETS_JSON=
