DEVICE_UID=feeder-001
FISH_FEEDER_DEVICE_API_KEY=replace-with-a-long-random-value
FISH_FEEDER_CREDENTIAL_PEPPER=replace-with-a-separate-long-random-value
FISH_FEEDER_ADMIN_USERNAME=admin
FISH_FEEDER_ADMIN_PASSWORD=replace-with-a-long-random-password
FISH_FEEDER_JWT_SECRET=replace-with-at-least-32-random-characters
FISH_FEEDER_CORS_ORIGINS=http://localhost:8080
MQTT_SHARED_SECRET=replace-with-a-separate-device-message-signing-secret
# For multiple devices, configure matching JSON maps on the bridge:
# DEVICE_CREDENTIALS_JSON={"feeder-001":"api-key-one","feeder-002":"api-key-two"}
# MQTT_SHARED_SECRETS_JSON={"feeder-001":"mqtt-secret-one","feeder-002":"mqtt-secret-two"}
